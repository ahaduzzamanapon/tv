              "host": ["{{base_url}}"],
              "path": ["api","v1","movies"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "Response-এ `available_filters.categories`, `available_filters.languages`, `available_filters.qualities` দিয়ে filter dropdown populate করুন।"
