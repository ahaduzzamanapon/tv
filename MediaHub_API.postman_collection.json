          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/movies?category=Bengali Dubbed&language=Bengali Dubbed&sort=newest&page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api","v1","movies"],
              "query": [
